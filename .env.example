# Copy this file to ".env" in the same folder and fill in real values.
# Never commit the real .env file to GitHub.

# Local Postgres connection string (see setup.sql for creating this db/user)
DATABASE_URL=postgresql://docapp_user:docapp_pass@localhost:5432/docapp

# Any long random string. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace-this-with-a-long-random-string

# Where uploaded file attachments are stored on disk
UPLOAD_FOLDER=uploads
